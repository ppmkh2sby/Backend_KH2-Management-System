{
  "ApplicationMetadata": {
    "Name": "KH2 Management System API",
    "Version": "v1"
  },
  "Jwt": {
    "Issuer": "https://api.example.com",
    "Audience": "https://app.example.com",
    "SecretKey": "REPLACE_WITH_A_LONG_RANDOM_SECRET_MIN_32_CHARS",
    "AccessTokenLifetimeMinutes": 60,
    "RefreshTokenLifetimeDays": 7
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=127.0.0.1;Port=5432;Database=kh2_management_system;Username=kh2_app;Password=REPLACE_ME"
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "ReverseProxy": {
    "ForwardLimit": 1,
    "KnownProxies": [
      "127.0.0.1",
      "::1"
    ],
    "KnownNetworks": []
  },
  "Database": {
    "MigrateOnStartup": true,
    "SeedOnStartup": false,
    "SeedSampleDataOnStartup": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "api.example.com"
}
